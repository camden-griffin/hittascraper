# Required — generate a long random string, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Optional — default user created on first run if no users exist in the DB
DEFAULT_EMAIL=admin@crm.local
DEFAULT_PASSWORD=changeme

# Optional — tighten CORS in production (set to your frontend domain)
# CORS_ORIGIN=https://your-domain.com

# Optional — port for the Express server (default 3001)
# PORT=3001
